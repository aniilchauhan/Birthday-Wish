# --- Local: copy to `.env` (gitignored). Same names on the host (e.g. Vercel). ---
#
# Vercel: Project → Settings → Environment Variables. Add each key for Production
# (and Preview if you want previews to work). Redeploy after changing vars.
# - GEMINI_API_KEY, GOOGLE_MAPS_API_KEY: needed at *build* time (Vite bakes them in).
# - MONGODB_URI: *runtime* for serverless `/api/surprise`.
# - VITE_* : *build* time for the browser bundle.

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Google Maps Embed API (used in App.tsx). Set on Vercel too so production builds get the key.
GOOGLE_MAPS_API_KEY="MY_GOOGLE_MAPS_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MongoDB Atlas (Vercel serverless API: /api/surprise). Required for short share links (?k=).
MONGODB_URI="mongodb+srv://USER:PASS@cluster.mongodb.net/birthday-wish?retryWrites=true&w=majority"

# Optional: full site origin where `/api/surprise` exists (no trailing slash).
# On Vercel with this repo, leave unset — same origin works.
#
# Local `npm run dev` (Vite only) does NOT run `/api/*` → 404 unless you proxy or use vercel dev.
# Short `?k=` links while on LAN (e.g. http://192.168.x.x:3000): set proxy to your live site (no trailing slash):
#   API_PROXY_TARGET="https://your-app.vercel.app"
# Then restart `npm run dev`. Browser still calls `/api/surprise`; Vite forwards to Vercel.
# Alternatives: `npx vercel dev`, or VITE_API_BASE_URL (direct cross-origin; API must allow CORS).
# VITE_API_BASE_URL="https://your-app.vercel.app"
